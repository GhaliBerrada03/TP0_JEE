<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0"
         metadata-complete="true">
    
    <display-name>Simple Inventory App</display-name>

    <listener>
        <listener-class>com.inventory.app.listener.HibernateListener</listener-class>
    </listener>

    <!-- User Management -->
    <servlet>
        <servlet-name>AppUserListServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.AppUserListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AppUserListServlet</servlet-name>
        <url-pattern>/app-users</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AppUserFormServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.AppUserFormServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AppUserFormServlet</servlet-name>
        <url-pattern>/app-user-form</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AppUserCreateServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.AppUserCreateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AppUserCreateServlet</servlet-name>
        <url-pattern>/app-user-create</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AppUserUpdateServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.AppUserUpdateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AppUserUpdateServlet</servlet-name>
        <url-pattern>/app-user-update</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AppUserDeleteServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.AppUserDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AppUserDeleteServlet</servlet-name>
        <url-pattern>/app-user-delete</url-pattern>
    </servlet-mapping>

    <!-- Stock Management -->
    <servlet>
        <servlet-name>StockItemListServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.StockItemListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StockItemListServlet</servlet-name>
        <url-pattern>/inventory</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StockItemFormServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.StockItemFormServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StockItemFormServlet</servlet-name>
        <url-pattern>/stock-form</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StockItemCreateServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.StockItemCreateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StockItemCreateServlet</servlet-name>
        <url-pattern>/stock-create</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StockItemUpdateServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.StockItemUpdateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StockItemUpdateServlet</servlet-name>
        <url-pattern>/stock-update</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StockItemDeleteServlet</servlet-name>
        <servlet-class>com.inventory.app.controller.StockItemDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StockItemDeleteServlet</servlet-name>
        <url-pattern>/stock-delete</url-pattern>
    </servlet-mapping>
    
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
